{
   "height": 32,
   "spacing": 4,
   "layer": "top",
   "position": "top",
   "modules-left": [
      "custom/spacer",
      "custom/logout",
      "custom/reboot",
      "custom/shutdown"
   ],
   "modules-center": [
      "clock"
   ],
   "modules-right": [
      "bluetooth",
      "network",
      "backlight",
      "pulseaudio",
      "power-profiles-daemon",
      "battery",
      "custom/spacer"
   ],
   "bluetooth": {
      "on-click": "blueman-manager",
      "format": "ΎΛΥ   BT"
   },
   "network": {
      "format-wifi": "{icon}   {essid} ({signalStrength}%)",
      "format-ethernet": "Ό╜Ε    {ifname}",
      "format-disconnected": "ΎΕπ   Disconnected",
      "max-length": 50,
      "on-click": "kitty -e 'nmtui'",
      "format-icons": [
         "≤░νψ",
         "≤░νθ",
         "≤░νλ",
         "≤░νξ",
         "≤░νρ"
      ]
   },
   "battery": {
      "format": "{icon} {capacity}%",
      "format-icons": [
         "≤░Β╗",
         "≤░Β╜",
         "≤░Β┐",
         "≤░ΓΒ",
         "≤░Β╣"
      ]
   },
   "clock": {
      "timezone": "America/Los Angeles",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
   },
   "backlight": {
      "format": "{icon}    {percent}% ",
      "format-icons": [
         "ΎΗΖ ",
         "ΎΕΣ "
      ]
   },
   "pulseaudio": {
      "format": "{icon}   {volume}%  {format_source}",
      "format-bluetooth": "{icon}   {volume}%  {format_source}",
      "format-bluetooth-muted": "ΎγσΎΛΦ {format_source}",
      "format-muted": "Ύγσ {format_source}",
      "format-source": "{volume}% ΎΕ░",
      "format-source-muted": "ΎΕ▒",
      "format-icons": [
      	"ΎΑο ",
      	"ΎΑπ ",
      	"ΎΑπ ",
      	"ΎΑρ ",
      ],
      "on-click": "pavucontrol"
   },
   "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
         "locked": "ΎΑμ",
         "unlocked": "ΎΓε"
      }
   },
   "hyprland/mode": {
      "format": "<span style=\"italic\">{}</span>"
   },
   "hyprland/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
         "",
         "ΎΜΤ"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
   },
   "mpd": {
      "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
      "format-disconnected": "Disconnected ΎΑΒ",
      "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
      "unknown-tag": "N/A",
      "interval": 5,
      "consume-icons": {
         "on": "ΎΔΕ "
      },
      "random-icons": {
         "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
         "on": "ΎΒ┤ "
      },
      "repeat-icons": {
         "on": "ΎΑη "
      },
      "single-icons": {
         "on": "ΎΑη1 "
      },
      "state-icons": {
         "paused": "ΎΒΝ",
         "playing": "ΎΒΜ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)"
   },
   "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
         "activated": "ΎΒχ",
         "deactivated": "ΎΒ░"
      }
   },
   "tray": {
      "spacing": 10
   },
   "cpu": {
      "format": "{usage}% ΎΜδ",
      "tooltip": false
   },
   "memory": {
      "format": "{}% ΎΔΚ"
   },
   "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": [
         "Ύζτ",
         "ΎΜΚ",
         "Ύζσ"
      ]
   },
   "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
         "default": "ΎΔπ ",
         "performance": "ΎΔπ ",
         "balanced": "ΎΚΟ ",
         "power-saver": "ΎΒυ "
      }
   },
   "custom/spacer": {
      "format": "  "
   },
   "custom/logout": {
      "format": "≤░ΙΗ ",
      "on-click": "hyprctl dispatch exit"
   },
   "custom/shutdown": {
      "format": "≤░νΓ ",
      "on-click": "shutdown"
   },
   "custom/reboot": {
      "format": "≤░ΣΥ ",
      "on-click": "reboot"
   }
}	
